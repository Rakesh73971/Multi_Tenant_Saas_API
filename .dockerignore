# Ignore virtual environment
venv/
.venv/
env/
ENV/

# Ignore git repository
.git/
.gitignore

# Ignore python caches and compiled files
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Ignore local database and test files
*.sqlite3
.pytest_cache/
.coverage
htmlcov/

# Ignore local environment files (to prevent baking secrets into the image)
.env

# Ignore system files
.DS_Store
Thumbs.db
